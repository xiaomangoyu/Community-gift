{
  "version": 1,
  "purpose": "Stable product-safe color palettes for community gift lightstick prompts.",
  "rules": [
    "CSV primary_color is the streamer identity anchor, not the whole product palette.",
    "main_color is the dominant product color anchor used for shell/core/rim placement.",
    "palette is the final 3-5 color product set used in prompts.",
    "Pure black is never used as a large product body color on black background; convert it to graphite/gunmetal/smoke-gray variants.",
    "Each generated lightstick should use one main_color plus 2-4 supporting palette colors."
  ],
  "palettes": [
    {
      "id": "black_safe",
      "name": "Black Theme Safe Product Palette",
      "main_color": "烟灰",
      "palette": ["烟灰", "枪灰银", "冷白", "少量金属银", "一处主题色高光"],
      "materials": ["烟灰半透明树脂", "枪灰珠光漆面", "冷白晶体内芯", "镜面银色细包边"],
      "match_terms": ["黑", "black", "暗", "夜色", "dark"],
